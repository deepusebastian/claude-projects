# Database
# Local dev: SQLite
DATABASE_URL="file:./dev.db"

# Production/UAT: Neon Postgres (set both vars)
# DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true"
# DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-change-in-production"

# Stripe
STRIPE_SECRET_KEY="sk_test_your_key_here"
STRIPE_PUBLISHABLE_KEY="pk_test_your_key_here"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# Google OAuth (optional — leave blank to use email/password only)
# Get credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Set to "true" once Google OAuth keys are filled in above
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED="false"
